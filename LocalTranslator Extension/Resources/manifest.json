{
  "manifest_version": 3,
  "name": "Local Translator",
  "version": "0.2.0",
  "description": "Offline image translator: detects Japanese/Chinese text in speech bubbles and overlays English translations. Translation runs entirely on-device via Apple's Translation framework — no internet required.",
  "default_locale": "en",

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Local Translator"
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/bubble-detector.js",
        "lib/ocr.js",
        "lib/overlay.js",
        "content.js"
      ],
      "css": ["overlay.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "nativeMessaging"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "lib/*",
        "vendor/*",
        "vendor/tesseract/*",
        "vendor/traineddata/*",
        "dictionary/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self'; default-src 'self'"
  }
}
